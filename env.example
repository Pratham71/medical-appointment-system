# ── Environment variables ─────────────────────────────────────────────────────
# This file is committed to the repo as a safe template.
# setup.sh copies it to .env automatically on first run.
# Never commit .env itself — it is in .gitignore.

ENVIRONMENT=development
DATABASE_PROVIDER=mysql

# MYSQL_HOST is overridden to "db" inside Docker by docker-compose.yml.
# This value is only used when running outside Docker.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=medical_appointment_system

# Generated automatically by setup.sh — do not set this by hand.
JWT_SECRET_KEY=

RATE_LIMIT_ENABLED=true
